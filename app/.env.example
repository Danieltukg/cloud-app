# Скопируй в .env и подставь свои значения: cp .env.example .env
# .env не коммитится (см. .gitignore).

# --- База данных ---
# Без этой строки используется локальный SQLite (файл vertex.db).
# DATABASE_URL=postgresql://vertex:secret@localhost:5432/vertex

# --- Инициализация схемы ---
# true  — таблицы создаются автоматически при старте (удобно для dev/SQLite)
# false — схемой управляет Alembic; запускай `alembic upgrade head`
AUTO_CREATE_DB=true

# Засеивать начальные данные, если база пуста
AUTO_SEED=true

# --- Ожидание БД на старте (для контейнеров) ---
DB_WAIT_RETRIES=15
DB_WAIT_DELAY=2.0
